# ==============================
# 订阅管理平台 - 环境变量配置
# ==============================
# 复制此文件为 .env 并填入实际值

# ---- 数据库（必填）----
DATABASE_URL="mysql://root:your_password@localhost:3306/sub_manager"

# ---- NextAuth 认证（必填）----
# 生成方式: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ---- OAuth 登录（可选）----
# GITHUB_ID=""
# GITHUB_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ---- 邮箱扫描 LLM（可选）----
# LLM_API_URL="https://api.openai.com/v1/chat/completions"
# LLM_API_KEY=""
# LLM_MODEL="gpt-4o-mini"

# ---- Docker Compose 专用（可选）----
# MYSQL_ROOT_PASSWORD="submanager"
# MYSQL_DATABASE="sub_manager"
# PORT=3000
